# Cérebro (obrigatório) — sua chave da Anthropic
ANTHROPIC_API_KEY=

# Modelo da Anthropic usado pelo /api/cron. Opcional (padrão: claude-sonnet-4-6).
ANTHROPIC_MODEL=

# Dados reais de Ads (Meta/TikTok/Google) via Windsor.ai
WINDSOR_API_KEY=

# Para onde o relatório diário é enviado (webhook: WhatsApp/Slack/n8n/e-mail). Opcional.
NOTIFY_WEBHOOK=

# Senha pra proteger o /api/cron. ATENÇÃO: o cron do Vercel funciona sem isso (header x-vercel-cron),
# mas SEM CRON_SECRET qualquer um pode chamar /api/cron manualmente e queimar tokens da Anthropic.
# Defina um valor forte em produção.
CRON_SECRET=

# WhatsApp Cloud API nativo (opcional) — relatório vai direto pro seu WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=
